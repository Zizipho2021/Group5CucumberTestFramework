<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Sequential Test Suite" verbose="1" parallel="false" thread-count="1">
    <listeners>
        <listener class-name="utils.Listener"/>
    </listeners>

    <test name="Registration" preserve-order="true">
        <classes>
            <class name="runners.RegistrationRunner"/>
        </classes>
    </test>
    <test name="Login" preserve-order="true">
    <classes>
        <class name="runners.LoginRunner"/>
    </classes>
    </test>
    <test name="Admin" preserve-order="true">
        <classes>
            <class name="runners.AdminRunner"/>
        </classes>
    </test>
    <test name="Delete" preserve-order="true">
        <classes>
            <class name="runners.DeleteUserRunner"/>
        </classes>
    </test>


</suite>
